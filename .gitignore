# dependencies
/node_modules

# next.js
/.next
/out

# production (Next.js build output is in .next; keep /build for icons/packaging assets)
# Allow icons + source logo so installers can be built from a clean clone.
/build/*
!/build/icon.ico
!/build/icon.png
!/build/source-logo.png

# electron
/dist-electron

# misc
.DS_Store
*.pem
*.bak
/tmp

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secrets / local config — never commit
.env
.env.*
!.env.example
*.key
*.p12
*.pfx
credentials.json
secrets.json

# runtime logs
*.log
codebuddy-debug.log

# per-user project dumps written by CodeBuddy itself
/.codebuddy/agents/
/.codebuddy/conversations/
/.codebuddy/tasks/
/.codebuddy/members/
/.codebuddy/versions/
/.codebuddy/uploads/

# legacy per-agent worktrees
/.claude

# npm audit dumps
audit-*.json
*audit*.json
