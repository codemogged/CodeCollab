{
  "name": "codecollab",
  "version": "0.1.0",
  "description": "CodeCollab — local-first desktop workspace for collaborative vibe coding.",
  "author": "CodeCollab Contributors",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "homepage": "https://github.com/codemogged/codecollab",
  "repository": {
    "type": "git",
    "url": "https://github.com/codemogged/codecollab.git"
  },
  "bugs": {
    "url": "https://github.com/codemogged/codecollab/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:electron": "concurrently --kill-others \"next dev --turbopack --port 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:electron": "next build && electron-builder",
    "deploy": "next build && electron-builder && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-install.ps1",
    "build:icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icon.ps1",
    "postinstall": "electron-builder install-app-deps",
    "start": "next start",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.codecollab.app",
    "productName": "CodeCollab",
    "copyright": "Copyright © 2026 CodeCollab Contributors",
    "files": [
      "electron/**/*",
      "out/**/*"
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "afterPack": "scripts/after-pack.js",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CodeCollab",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerSidebar": null,
      "license": null
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "hyperswarm": "^4.17.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.21.0",
    "eslint-config-next": "15.2.4",
    "postcss": "^8.5.3",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "wait-on": "^9.0.4"
  }
}
